# 1) Load functions
devtools::load_all()
source_folder <- "L:/Projects_data/2022_Sodium_bicarbonate/1_Original data/2022-09-19 RP1 bicarbonate"
# Create project
project <- create_dld8_project(
source_folder = source_folder,
exclude_non_experimental = TRUE  # default: TRUE. Excludes cleaning/background protocols.
)
# Check files
print(project$dld8_files) # Nr. of experimental dld8 files found in your directory
print(project$excluded_dld8_files) # Nr. of dld8 files excluded (cleaning/background files)
# Check baseline / reference marks
validation <- validate_effective_markers(project)
validation[validation$baseline_ok == FALSE | validation$reference_ok == FALSE, ]
# Metadata checks
marks_df <- extract_marks_df(project)
metadata_df <- extract_metadata_df(project)
# Flux tables (enable verbose for debugging)
tables_by_protocol <- extract_flux_tables(project, format = "wide", group_by_protocol = TRUE, verbose = TRUE)
tables_wide <- extract_flux_tables(project, format = "wide", verbose = TRUE)
# sanity checks: baseline-corrected and FCR tables should have same number of
# rows as the uncorrected specific_flux output.  Previously these tables were
# coming back empty which broke downstream analysis.
stopifnot(nrow(tables_wide$specific_flux_bc) == nrow(tables_wide$specific_flux))
stopifnot(nrow(tables_wide$fcr) == nrow(tables_wide$specific_flux))
stopifnot(nrow(tables_wide$fcr_bc) == nrow(tables_wide$specific_flux))
stopifnot(is.environment(project$parsed_dld8))
