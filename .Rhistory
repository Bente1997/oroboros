tables_wide <- extract_flux_tables(project, format = "wide", verbose = TRUE)
# sanity checks: baseline-corrected and FCR tables should have same number of
# rows as the uncorrected specific_flux output.  Previously these tables were
# coming back empty which broke downstream analysis.
stopifnot(nrow(tables_wide$specific_flux_bc) == nrow(tables_wide$specific_flux))
stopifnot(nrow(tables_wide$fcr) == nrow(tables_wide$specific_flux))
stopifnot(nrow(tables_wide$fcr_bc) == nrow(tables_wide$specific_flux))
stopifnot(is.environment(project$parsed_dld8))
